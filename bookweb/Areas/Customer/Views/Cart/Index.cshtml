@model IEnumerable<ShoppingCart>
@{
    ViewData["Title"] = "Shopping Cart";
    var orderTotal = (double)ViewBag.OrderTotal;
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-cart3 me-2" style="color: #17A34A;"></i>Shopping Cart
        </h2>
        @if (Model.Any())
        {
            <form asp-action="Clear" method="post">
                <button type="submit" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-trash me-1"></i>Clear Cart
                </button>
            </form>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="card border shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-cart-x" style="font-size: 4rem; color: #cbd5e1;"></i>
                <h4 class="mt-3 text-secondary">Your cart is empty</h4>
                <p class="text-muted">Browse our collection and add some books to your cart!</p>
                <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn text-white mt-2" style="background: #17A34A;">
                    <i class="bi bi-book me-1"></i>Browse Books
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Cart Items -->
            <div class="col-lg-8">
                <div class="card border shadow-sm">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4" style="width: 80px;"></th>
                                        <th>Book</th>
                                        <th class="text-center" style="width: 160px;">Quantity</th>
                                        <th class="text-end" style="width: 100px;">Price</th>
                                        <th class="text-end pe-4" style="width: 100px;">Subtotal</th>
                                        <th style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                                {
                                                    <img src="@item.Product.ImageUrl" alt="@item.Product.Title"
                                                         class="rounded shadow-sm" style="width: 55px; height: 75px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="rounded d-flex align-items-center justify-content-center" style="width: 55px; height: 75px; background: #e2e8f0;">
                                                        <i class="bi bi-book text-secondary"></i>
                                                    </div>
                                                }
                                            </td>
                                            <td>
                                                <a asp-area="Customer" asp-controller="Home" asp-action="Details" asp-route-id="@item.ProductId"
                                                   class="text-decoration-none text-dark fw-semibold">
                                                    @item.Product.Title
                                                </a>
                                                <br />
                                                <small class="text-muted">@item.Product.Author</small>
                                                @if (item.Product.Category != null)
                                                {
                                                    <br />
                                                    <span class="badge" style="font-size: 0.65rem; background: rgba(23,163,74,0.1); color: #17A34A;">
                                                        @item.Product.Category.Name
                                                    </span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <form asp-action="UpdateQuantity" method="post" class="d-inline-flex align-items-center gap-1">
                                                    <input type="hidden" name="cartId" value="@item.Id" />
                                                    <button type="submit" name="count" value="@(item.Count - 1)" class="btn btn-sm btn-outline-secondary rounded-circle" style="width:30px;height:30px;padding:0;">
                                                        <i class="bi bi-dash"></i>
                                                    </button>
                                                    <span class="fw-semibold mx-2" style="min-width: 24px; text-align: center;">@item.Count</span>
                                                    <button type="submit" name="count" value="@(item.Count + 1)" class="btn btn-sm btn-outline-secondary rounded-circle" style="width:30px;height:30px;padding:0;">
                                                        <i class="bi bi-plus"></i>
                                                    </button>
                                                </form>
                                            </td>
                                            <td class="text-end fw-medium">@item.Price.ToString("c")</td>
                                            <td class="text-end pe-4 fw-bold" style="color: #17A34A;">@((item.Price * item.Count).ToString("c"))</td>
                                            <td>
                                                <form asp-action="Remove" method="post">
                                                    <input type="hidden" name="cartId" value="@item.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="card border shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="fw-bold mb-0"><i class="bi bi-receipt me-2"></i>Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Items (@Model.Sum(x => x.Count))</span>
                            <span class="fw-medium">@orderTotal.ToString("c")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Shipping</span>
                            <span class="fw-medium text-success">Free</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between mb-3">
                            <span class="fw-bold fs-5">Total</span>
                            <span class="fw-bold fs-5" style="color: #17A34A;">@orderTotal.ToString("c")</span>
                        </div>
                        <button class="btn text-white w-100 fw-semibold py-2" style="background: #17A34A;" disabled>
                            <i class="bi bi-lock me-1"></i>Proceed to Checkout
                        </button>
                        <p class="text-center text-muted small mt-2 mb-0">Checkout coming soon</p>
                    </div>
                </div>
                <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-100 mt-3">
                    <i class="bi bi-arrow-left me-1"></i>Continue Shopping
                </a>
            </div>
        </div>
    }
</div>
