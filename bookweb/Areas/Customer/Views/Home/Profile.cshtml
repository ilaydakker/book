@model ApplicationUser
@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
                <div class="card-header bg-white border-0 pt-4 pb-0 text-center" style="border-radius: 1rem 1rem 0 0;">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                         style="width:64px; height:64px; background: linear-gradient(135deg, #065f46, #10b981);">
                        <i class="bi bi-person-fill text-white fs-3"></i>
                    </div>
                    <h4 class="fw-bold mb-1">My Profile</h4>
                    <p class="text-muted small">Manage your account information</p>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-action="Profile">
                        @Html.AntiForgeryToken()

                        <!-- Email (readonly) -->
                        <div class="mb-3">
                            <label class="form-label fw-medium">Email</label>
                            <input type="email" class="form-control bg-light" value="@Model.Email" readonly disabled />
                            <small class="text-muted">Email cannot be changed.</small>
                        </div>

                        <!-- Name -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-medium"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <!-- Phone -->
                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-medium">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>

                        <hr class="my-3" />
                        <h6 class="fw-bold text-muted mb-3"><i class="bi bi-geo-alt me-1"></i>Address</h6>

                        <div class="mb-3">
                            <label asp-for="StreetAddress" class="form-label fw-medium">Street Address</label>
                            <input asp-for="StreetAddress" class="form-control" />
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="City" class="form-label fw-medium">City</label>
                                <input asp-for="City" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="State" class="form-label fw-medium">State</label>
                                <input asp-for="State" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="PostalCode" class="form-label fw-medium">Postal Code</label>
                                <input asp-for="PostalCode" class="form-control" />
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-lg text-white fw-semibold"
                                    style="background: linear-gradient(135deg, #065f46, #10b981); border:none;">
                                <i class="bi bi-check-lg me-2"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
