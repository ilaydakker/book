@model Shelf
@{
    ViewData["Title"] = Model.Name;
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Shelves" class="text-decoration-none text-secondary small fw-medium d-inline-flex align-items-center gap-1 mb-2">
                <i class="bi bi-arrow-left"></i> Back to My Shelves
            </a>
            <h2 class="fw-bold mb-1"><i class="bi bi-bookmark-star text-primary me-2"></i>@Model.Name</h2>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="text-secondary mb-0">@Model.Description</p>
            }
            <small class="text-muted">@Model.ShelfItems.Count book@(Model.ShelfItems.Count != 1 ? "s" : "") &middot; Created @Model.CreatedAt.ToString("MMM dd, yyyy")</small>
        </div>
        <a asp-action="Index" class="btn btn-outline-dark">
            <i class="bi bi-plus-lg me-1"></i>Add Books
        </a>
    </div>

    @if (Model.ShelfItems.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var item in Model.ShelfItems.OrderByDescending(si => si.DateAdded))
            {
                var product = item.Product!;
                <div class="col" id="shelf-book-@product.Id">
                    <div class="card h-100 border shadow-sm position-relative">
                        <!-- Remove from shelf -->
                        <button class="btn btn-sm position-absolute top-0 end-0 m-2 remove-from-shelf-btn"
                                data-shelf-id="@Model.Id" data-product-id="@product.Id"
                                title="Remove from shelf"
                                style="z-index: 2; background: rgba(255,255,255,0.9); border-radius: 50%; width:36px; height:36px; padding:0;">
                            <i class="bi bi-x-lg text-muted"></i>
                        </button>

                        <a asp-action="Details" asp-route-productId="@product.Id" class="text-decoration-none">
                            <div style="aspect-ratio: 3/4; overflow: hidden;">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" class="w-100 h-100" style="object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                        <i class="bi bi-book display-3 text-secondary"></i>
                                    </div>
                                }
                            </div>
                        </a>
                        <div class="card-body">
                            <span class="badge bg-secondary mb-2">@product.Category?.Name</span>
                            <h6 class="card-title fw-semibold mb-2">
                                <a asp-action="Details" asp-route-productId="@product.Id" class="text-decoration-none text-dark">
                                    @product.Title
                                </a>
                            </h6>
                            <p class="text-secondary small mb-2">by @product.Author</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-success">@product.Price.ToString("0.00")</span>
                                <a asp-action="Details" asp-route-productId="@product.Id" class="btn btn-sm btn-outline-dark">View</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-book display-1 text-muted"></i>
            <h4 class="text-muted mt-3">This shelf is empty</h4>
            <p class="text-secondary">Browse books and add them to this shelf!</p>
            <a asp-action="Index" class="btn btn-outline-dark">Browse Books</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.remove-from-shelf-btn').on('click', function (e) {
                e.preventDefault();
                var btn = $(this);
                var shelfId = btn.data('shelf-id');
                var productId = btn.data('product-id');

                $.ajax({
                    url: '/Customer/Home/ToggleShelfItem',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ shelfId: shelfId, productId: productId }),
                    success: function (data) {
                        if (data.success && !data.added) {
                            $('#shelf-book-' + productId).fadeOut(300, function () { $(this).remove(); });
                            toastr.success(data.message);
                        }
                    },
                    error: function () { toastr.error('Something went wrong.'); }
                });
            });
        });
    </script>
}
