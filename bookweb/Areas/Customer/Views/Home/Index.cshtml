@model IEnumerable<Product>
@{
    var categories = ViewBag.Categories as IEnumerable<Category>;
    var currentSearch = ViewBag.CurrentSearch as string;
    var currentCategoryId = ViewBag.CurrentCategoryId as int?;
    var currentSort = ViewBag.CurrentSort as string;
    var wishlistIds = ViewBag.WishlistIds as List<int>;
    var userBookStatuses = ViewBag.UserBookStatuses as Dictionary<int, int>;
    var averageRatings = ViewBag.AverageRatings as Dictionary<int, double>;
    var reviewCounts = ViewBag.ReviewCounts as Dictionary<int, int>;
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    int totalItems = ViewBag.TotalItems;
}
<partial name="_Hero" />

<div class="container py-5" id="catalog">
    <!-- Search & Filter Section -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem; background: #fff;">
        <div class="card-body p-3 p-md-4">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <!-- Search -->
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" value="@currentSearch" class="form-control border-start-0"
                               placeholder="Search by title or author..." />
                    </div>
                </div>
                <!-- Category -->
                <div class="col-md-3">
                    <select name="categoryId" class="form-select">
                        <option value="">All Categories</option>
                        @if (categories != null)
                        {
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id" selected="@(currentCategoryId == cat.Id)">@cat.Name</option>
                            }
                        }
                    </select>
                </div>
                <!-- Sort -->
                <div class="col-md-2">
                    <select name="sortBy" class="form-select">
                        <option value="">Sort by</option>
                        <option value="newest" selected="@(currentSort == "newest")">Newest</option>
                        <option value="price_asc" selected="@(currentSort == "price_asc")">Price: Low → High</option>
                        <option value="price_desc" selected="@(currentSort == "price_desc")">Price: High → Low</option>
                        <option value="title_asc" selected="@(currentSort == "title_asc")">Title: A → Z</option>
                        <option value="title_desc" selected="@(currentSort == "title_desc")">Title: Z → A</option>
                    </select>
                </div>
                <!-- Buttons -->
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn text-white flex-grow-1" style="background: linear-gradient(135deg, #065f46, #10b981);">
                        <i class="bi bi-funnel me-1"></i>Filter
                    </button>
                    @if (!string.IsNullOrEmpty(currentSearch) || currentCategoryId.HasValue || !string.IsNullOrEmpty(currentSort))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Results Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Our Collection</h2>
            <p class="text-secondary mb-0">
                @totalItems book(s) found
                @if (!string.IsNullOrEmpty(currentSearch))
                {
                    <span>for "<strong>@currentSearch</strong>"</span>
                }
                @if (totalPages > 1)
                {
                    <span>— Page @currentPage of @totalPages</span>
                }
            </p>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-action="MyBooks" class="btn btn-outline-dark btn-sm">
                <i class="bi bi-book-half me-1"></i>My Books
            </a>
        }
    </div>

    @if (Model.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 border shadow-sm book-card position-relative">
                        <!-- Reading Status Indicator -->
                        @if (wishlistIds != null && wishlistIds.Contains(product.Id))
                        {
                            var statusVal = userBookStatuses != null && userBookStatuses.ContainsKey(product.Id) ? userBookStatuses[product.Id] : 0;
                            <span class="position-absolute top-0 start-0 m-2 badge @(statusVal == 0 ? "bg-warning text-dark" : statusVal == 1 ? "bg-primary" : "bg-success")" style="z-index: 2; font-size: 0.6rem;">
                                @(statusVal == 0 ? "Want to Read" : statusVal == 1 ? "Reading" : "Read")
                            </span>
                        }

                        <!-- Wishlist Heart -->
                        <button class="btn btn-sm position-absolute top-0 end-0 m-2 wishlist-btn"
                                data-product-id="@product.Id"
                                style="z-index: 2; background: rgba(255,255,255,0.9); border-radius: 50%; width:36px; height:36px; padding:0;">
                            @if (wishlistIds != null && wishlistIds.Contains(product.Id))
                            {
                                <i class="bi bi-heart-fill text-danger"></i>
                            }
                            else
                            {
                                <i class="bi bi-heart text-muted"></i>
                            }
                        </button>

                        <a asp-action="Details" asp-route-productId="@product.Id" class="text-decoration-none">
                            <div style="aspect-ratio: 3/4; overflow: hidden;">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" class="w-100 h-100" style="object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                        <i class="bi bi-book display-3 text-secondary"></i>
                                    </div>
                                }
                            </div>
                        </a>
                        <div class="card-body">
                            <span class="badge bg-secondary mb-2">@product.Category?.Name</span>
                            <h6 class="card-title fw-semibold mb-2" style="min-height: 2.5rem;">
                                <a asp-action="Details" asp-route-productId="@product.Id" class="text-decoration-none text-dark">
                                    @product.Title
                                </a>
                            </h6>
                            <p class="text-secondary small mb-2">by @product.Author</p>
                            @{
                                var hasRating = averageRatings != null && averageRatings.ContainsKey(product.Id);
                                var avgRating = hasRating ? averageRatings[product.Id] : 0;
                                var rCount = reviewCounts != null && reviewCounts.ContainsKey(product.Id) ? reviewCounts[product.Id] : 0;
                            }
                            @if (hasRating)
                            {
                                <div class="d-flex align-items-center gap-1 mb-2">
                                    <span class="text-warning small">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi @(i <= Math.Round(avgRating) ? "bi-star-fill" : "bi-star")"></i>
                                        }
                                    </span>
                                    <span class="text-muted" style="font-size: 0.7rem;">(@rCount)</span>
                                </div>
                            }
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fw-bold text-success">@product.Price.ToString("0.00")</span>
                                    @if (product.ListPrice > product.Price)
                                    {
                                        <small class="text-decoration-line-through text-muted ms-1">@product.ListPrice.ToString("0.00")</small>
                                    }
                                </div>
                                <a asp-action="Details" asp-route-productId="@product.Id" class="btn btn-sm btn-outline-dark">
                                    View
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-5">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-search="@currentSearch" asp-route-categoryId="@currentCategoryId" asp-route-sortBy="@currentSort" asp-route-page="@(currentPage - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @{
                        int startPage = Math.Max(1, currentPage - 2);
                        int endPage = Math.Min(totalPages, currentPage + 2);
                        if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" asp-route-search="@currentSearch" asp-route-categoryId="@currentCategoryId" asp-route-sortBy="@currentSort" asp-route-page="1">1</a>
                            </li>
                            if (startPage > 2)
                            {
                                <li class="page-item disabled"><span class="page-link">…</span></li>
                            }
                        }
                        for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-search="@currentSearch" asp-route-categoryId="@currentCategoryId" asp-route-sortBy="@currentSort" asp-route-page="@i">@i</a>
                            </li>
                        }
                        if (endPage < totalPages)
                        {
                            if (endPage < totalPages - 1)
                            {
                                <li class="page-item disabled"><span class="page-link">…</span></li>
                            }
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" asp-route-search="@currentSearch" asp-route-categoryId="@currentCategoryId" asp-route-sortBy="@currentSort" asp-route-page="@totalPages">@totalPages</a>
                            </li>
                        }
                    }
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-search="@currentSearch" asp-route-categoryId="@currentCategoryId" asp-route-sortBy="@currentSort" asp-route-page="@(currentPage + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-search display-1 text-muted"></i>
            <h4 class="text-muted mt-3">No books found</h4>
            <p class="text-secondary">Try adjusting your search or filter criteria.</p>
            <a asp-action="Index" class="btn btn-outline-dark">View All Books</a>
        </div>
    }
</div>
<partial name="_Newsletter" />

@section Scripts {
    <script src="~/js/wishlist.js"></script>
}