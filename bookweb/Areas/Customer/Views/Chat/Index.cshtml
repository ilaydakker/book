@{
    ViewData["Title"] = "Book Assistant";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var conversations = ViewBag.Conversations as List<BookWeb.Models.ChatConversation> ?? new List<BookWeb.Models.ChatConversation>();
    var activeConversation = ViewBag.ActiveConversation as BookWeb.Models.ChatConversation;
}

<div class="container-fluid px-0" style="height: calc(100vh - 72px); overflow: hidden;">
    <div class="row g-0 h-100">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2 border-end d-flex flex-column h-100" style="background: #1a1a2e;">
            <div class="p-3">
                <button id="new-chat-btn" class="btn btn-sm w-100 text-white d-flex align-items-center justify-content-center gap-2" 
                        style="background: linear-gradient(135deg, #065f46, #10b981); border: none;">
                    <i class="bi bi-plus-lg"></i> New Chat
                </button>
            </div>
            <div class="flex-grow-1 overflow-auto px-2 pb-3" id="conversation-list">
                @foreach (var conv in conversations)
                {
                    <div class="conversation-item d-flex align-items-center gap-2 px-3 py-2 rounded mb-1 @(activeConversation?.Id == conv.Id ? "active" : "")"
                         data-id="@conv.Id" style="cursor: pointer;">
                        <i class="bi bi-chat-left-text text-secondary" style="font-size: 0.8rem;"></i>
                        <span class="text-truncate flex-grow-1 text-light" style="font-size: 0.82rem;">@conv.Title</span>
                        <button class="btn btn-sm p-0 text-secondary delete-conv-btn border-0" data-id="@conv.Id" style="font-size: 0.75rem; visibility: hidden;">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                }
                @if (!conversations.Any())
                {
                    <p class="text-secondary text-center small mt-4" id="no-conversations-msg">No conversations yet</p>
                }
            </div>
        </div>

        <!-- Chat Area -->
        <div class="col-md-9 col-lg-10 d-flex flex-column h-100" style="background: #f8fafc;">
            <!-- Chat Header -->
            <div class="border-bottom px-4 py-3 bg-white d-flex align-items-center gap-2">
                <i class="bi bi-robot" style="font-size: 1.3rem; color: #10b981;"></i>
                <div>
                    <h6 class="mb-0 fw-semibold" id="chat-title">
                        @(activeConversation?.Title ?? "Book Assistant")
                    </h6>
                    <small class="text-muted">Ask me anything about books in our catalog</small>
                </div>
            </div>

            <!-- Messages -->
            <div class="flex-grow-1 overflow-auto p-4" id="chat-messages">
                @if (activeConversation != null && activeConversation.Messages.Any())
                {
                    foreach (var msg in activeConversation.Messages)
                    {
                        if (msg.Role == "user")
                        {
                            <div class="d-flex justify-content-end mb-4">
                                <div class="rounded-3 p-3 text-white shadow-sm" style="max-width: 70%; background: #065f46;">
                                    <p class="mb-0" style="font-size: 0.9rem; white-space: pre-wrap;">@msg.Content</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex gap-3 mb-4">
                                <div class="flex-shrink-0">
                                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 36px; height: 36px; background: rgba(16,185,129,0.1);">
                                        <i class="bi bi-robot" style="color: #10b981;"></i>
                                    </span>
                                </div>
                                <div class="bg-white border rounded-3 p-3 shadow-sm" style="max-width: 70%;">
                                    <div class="msg-content" style="font-size: 0.9rem;">@Html.Raw(FormatMessage(msg.Content))</div>
                                </div>
                            </div>
                        }
                    }
                }
                else if (activeConversation == null)
                {
                    <div class="d-flex flex-column align-items-center justify-content-center h-100 text-center">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px; background: rgba(16,185,129,0.1);">
                            <i class="bi bi-robot" style="font-size: 2.5rem; color: #10b981;"></i>
                        </div>
                        <h4 class="fw-bold mb-2">Book Assistant</h4>
                        <p class="text-muted mb-4" style="max-width: 400px;">I can help you discover books, get recommendations, find specific genres or authors from our catalog.</p>
                        <div class="d-flex flex-wrap gap-2 justify-content-center">
                            <button class="btn btn-outline-secondary btn-sm suggestion-btn">What am I currently reading?</button>
                            <button class="btn btn-outline-secondary btn-sm suggestion-btn">Give me 10 history books</button>
                            <button class="btn btn-outline-secondary btn-sm suggestion-btn">What are my books?</button>
                        </div>
                    </div>
                }
            </div>

            <!-- Input Area -->
            <div class="border-top bg-white p-3">
                <div class="mx-auto" style="max-width: 800px;">
                    <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                        <input type="text" id="chat-input" class="form-control border-0 px-4 py-3" 
                               placeholder="Ask about books..." style="font-size: 0.9rem; box-shadow: none;"
                               autocomplete="off" />
                        <button id="chat-send-btn" class="btn px-4" style="background: #10b981; color: white; border: none;">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                    <p class="text-center text-muted mt-2 mb-0" style="font-size: 0.7rem;">Powered by DeepSeek • Responses are based on our book catalog</p>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string FormatMessage(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        text = System.Net.WebUtility.HtmlEncode(text);
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\*\*(.*?)\*\*", "<strong>$1</strong>");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\*(.*?)\*", "<em>$1</em>");
        text = text.Replace("\n", "<br>");
        return text;
    }
}

@section Scripts {
    <style>
        .conversation-item:hover {
            background: rgba(255,255,255,0.05) !important;
        }
        .conversation-item:hover .delete-conv-btn {
            visibility: visible !important;
        }
        .conversation-item.active {
            background: rgba(16,185,129,0.15) !important;
        }
        .typing-dot {
            width: 8px; height: 8px;
            background: #10b981;
            border-radius: 50%;
            animation: typingBounce 1.4s infinite ease-in-out both;
        }
        .typing-dot:nth-child(1) { animation-delay: -0.32s; }
        .typing-dot:nth-child(2) { animation-delay: -0.16s; }
        @@keyframes typingBounce {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1); }
        }
    </style>
    <script>
        $(document).ready(function () {
            var currentConversationId = @(activeConversation?.Id.ToString() ?? "null");
            var isLoading = false;
            var messagesDiv = document.getElementById('chat-messages');

            // Scroll to bottom on load
            if (messagesDiv) messagesDiv.scrollTop = messagesDiv.scrollHeight;

            // New chat
            $('#new-chat-btn').on('click', function () {
                $.post('/Customer/Chat/NewConversation', function (data) {
                    if (data.success) {
                        window.location.href = '/Customer/Chat?conversationId=' + data.conversationId;
                    }
                });
            });

            // Click conversation
            $(document).on('click', '.conversation-item', function (e) {
                if ($(e.target).closest('.delete-conv-btn').length) return;
                var id = $(this).data('id');
                window.location.href = '/Customer/Chat?conversationId=' + id;
            });

            // Delete conversation
            $(document).on('click', '.delete-conv-btn', function (e) {
                e.stopPropagation();
                var id = $(this).data('id');
                if (!confirm('Delete this conversation?')) return;
                $.ajax({
                    url: '/Customer/Chat/DeleteConversation',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ conversationId: id }),
                    success: function () {
                        if (currentConversationId === id) {
                            window.location.href = '/Customer/Chat';
                        } else {
                            $('[data-id="' + id + '"].conversation-item').remove();
                        }
                    }
                });
            });

            // Send message
            $('#chat-send-btn').on('click', sendMessage);
            $('#chat-input').on('keydown', function (e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });

            // Suggestion buttons
            $('.suggestion-btn').on('click', function () {
                $('#chat-input').val($(this).text());
                sendMessage();
            });

            function sendMessage() {
                var msg = $('#chat-input').val().trim();
                if (!msg || isLoading) return;

                // Clear welcome screen
                if (!currentConversationId) {
                    $('#chat-messages').html('');
                }

                appendUserMessage(msg);
                $('#chat-input').val('');
                isLoading = true;
                $('#chat-send-btn').prop('disabled', true);

                var typingEl = appendTyping();

                $.ajax({
                    url: '/Customer/Chat/Ask',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ message: msg, conversationId: currentConversationId }),
                    success: function (data) {
                        typingEl.remove();
                        if (data.success) {
                            appendBotMessage(data.message);
                            // Update conversation ID if new
                            if (!currentConversationId && data.conversationId) {
                                currentConversationId = data.conversationId;
                                history.replaceState(null, '', '/Customer/Chat?conversationId=' + data.conversationId);
                                // Add to sidebar
                                var title = data.title || msg.substring(0, 50);
                                $('#no-conversations-msg').remove();
                                $('#conversation-list').prepend(
                                    '<div class="conversation-item d-flex align-items-center gap-2 px-3 py-2 rounded mb-1 active" data-id="' + data.conversationId + '" style="cursor: pointer;">' +
                                        '<i class="bi bi-chat-left-text text-secondary" style="font-size: 0.8rem;"></i>' +
                                        '<span class="text-truncate flex-grow-1 text-light" style="font-size: 0.82rem;">' + escapeHtml(title) + '</span>' +
                                        '<button class="btn btn-sm p-0 text-secondary delete-conv-btn border-0" data-id="' + data.conversationId + '" style="font-size: 0.75rem; visibility: hidden;"><i class="bi bi-trash"></i></button>' +
                                    '</div>'
                                );
                                $('#chat-title').text(title);
                            }
                        } else {
                            appendBotMessage(data.message || 'Something went wrong.');
                        }
                    },
                    error: function () {
                        typingEl.remove();
                        appendBotMessage('Sorry, I could not connect. Please try again.');
                    },
                    complete: function () {
                        isLoading = false;
                        $('#chat-send-btn').prop('disabled', false);
                    }
                });
            }

            function appendUserMessage(text) {
                var html = '<div class="d-flex justify-content-end mb-4">' +
                    '<div class="rounded-3 p-3 text-white shadow-sm" style="max-width: 70%; background: #065f46;">' +
                        '<p class="mb-0" style="font-size: 0.9rem; white-space: pre-wrap;">' + escapeHtml(text) + '</p>' +
                    '</div></div>';
                $('#chat-messages').append(html);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
            }

            function appendBotMessage(text) {
                var formatted = escapeHtml(text)
                    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                    .replace(/\*(.*?)\*/g, '<em>$1</em>')
                    .replace(/\n/g, '<br>');
                var html = '<div class="d-flex gap-3 mb-4">' +
                    '<div class="flex-shrink-0">' +
                        '<span class="d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 36px; height: 36px; background: rgba(16,185,129,0.1);">' +
                            '<i class="bi bi-robot" style="color: #10b981;"></i>' +
                        '</span>' +
                    '</div>' +
                    '<div class="bg-white border rounded-3 p-3 shadow-sm" style="max-width: 70%;">' +
                        '<div style="font-size: 0.9rem;">' + formatted + '</div>' +
                    '</div></div>';
                $('#chat-messages').append(html);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
            }

            function appendTyping() {
                var html = '<div class="typing-indicator d-flex gap-3 mb-4">' +
                    '<div class="flex-shrink-0">' +
                        '<span class="d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 36px; height: 36px; background: rgba(16,185,129,0.1);">' +
                            '<i class="bi bi-robot" style="color: #10b981;"></i>' +
                        '</span>' +
                    '</div>' +
                    '<div class="bg-white border rounded-3 p-3 shadow-sm">' +
                        '<div class="d-flex gap-1"><span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span></div>' +
                    '</div></div>';
                var $el = $(html);
                $('#chat-messages').append($el);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
                return $el;
            }

            function escapeHtml(text) {
                var div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }
        });
    </script>
}
