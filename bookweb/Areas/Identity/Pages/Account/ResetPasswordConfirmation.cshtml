@page
@{
    ViewData["Title"] = "Reset Password Confirmation";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4"
                 style="width:80px; height:80px; background: linear-gradient(135deg, #065f46, #10b981);">
                <i class="bi bi-check-circle-fill text-white fs-2"></i>
            </div>
            <h2 class="text-white fw-bold">Password Reset Successfully</h2>
            <p class="text-secondary">Your password has been reset. You can now sign in with your new password.</p>
            <a asp-page="./Login" class="btn btn-outline-light mt-3">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </a>
        </div>
    </div>
</div>
