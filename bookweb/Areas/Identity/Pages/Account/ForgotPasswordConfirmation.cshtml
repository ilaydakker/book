@page
@{
    ViewData["Title"] = "Forgot Password Confirmation";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4"
                 style="width:80px; height:80px; background: linear-gradient(135deg, #065f46, #10b981);">
                <i class="bi bi-envelope-check-fill text-white fs-2"></i>
            </div>
            <h2 class="text-white fw-bold">Check Your Email</h2>
            <p class="text-secondary">If an account with that email exists, a password reset link has been sent. Please check your terminal/console output.</p>
            <a asp-page="./Login" class="btn btn-outline-light mt-3">
                <i class="bi bi-arrow-left me-2"></i>Back to Login
            </a>
        </div>
    </div>
</div>
