@page
@model bookweb.Areas.Identity.Pages.Account.ConfirmEmailModel
@{
    ViewData["Title"] = "Confirm Email";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            @if (Model.StatusMessage != null && Model.StatusMessage.Contains("Thank you"))
            {
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4"
                     style="width:80px; height:80px; background: linear-gradient(135deg, #065f46, #10b981);">
                    <i class="bi bi-check-circle-fill text-white fs-2"></i>
                </div>
                <h2 class="text-white fw-bold">Email Confirmed!</h2>
                <p class="text-secondary">Your email has been confirmed successfully. You can now sign in.</p>
                <a asp-page="./Login" class="btn btn-outline-light mt-3">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </a>
            }
            else
            {
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4"
                     style="width:80px; height:80px; background: linear-gradient(135deg, #dc2626, #991b1b);">
                    <i class="bi bi-x-circle-fill text-white fs-2"></i>
                </div>
                <h2 class="text-white fw-bold">Email Confirmation Failed</h2>
                <p class="text-secondary">@Model.StatusMessage</p>
                <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-outline-light mt-3">
                    <i class="bi bi-house me-2"></i>Return to Home
                </a>
            }
        </div>
    </div>
</div>
