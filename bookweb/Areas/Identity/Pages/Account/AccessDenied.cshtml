@page
@{
    ViewData["Title"] = "Access Denied";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4"
                 style="width:80px; height:80px; background: linear-gradient(135deg, #dc2626, #991b1b);">
                <i class="bi bi-shield-lock-fill text-white fs-2"></i>
            </div>
            <h2 class="text-white fw-bold">Access Denied</h2>
            <p class="text-secondary">You do not have permission to access this resource.</p>
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-outline-light mt-3">
                <i class="bi bi-house me-2"></i>Return to Home
            </a>
        </div>
    </div>
</div>
