@page
@model bookweb.Areas.Identity.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h2 class="text-white">You have been logged out</h2>
            <p class="text-secondary">Thank you for visiting BookWeb.</p>
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-outline-light mt-3">
                <i class="bi bi-house me-2"></i>Return to Home
            </a>
        </div>
    </div>
</div>
