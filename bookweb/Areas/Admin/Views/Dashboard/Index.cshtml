@model BookWeb.Models.ViewModels.DashboardVM
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: #191414;">Dashboard</h2>
            <p class="text-muted mb-0">Welcome back, @User.Identity?.Name</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-area="Admin" asp-controller="Product" asp-action="Upsert" class="btn btn-sm text-white" style="background: linear-gradient(135deg, #065f46, #10b981);">
                <i class="bi bi-plus-lg me-1"></i>New Product
            </a>
            <a asp-area="Admin" asp-controller="Category" asp-action="Create" class="btn btn-sm btn-outline-dark">
                <i class="bi bi-plus-lg me-1"></i>New Category
            </a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center justify-content-center rounded-circle"
                         style="width:50px; height:50px; background: linear-gradient(135deg, #7c3aed, #a855f7);">
                        <i class="bi bi-book-fill text-white fs-5"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Total Products</p>
                        <h3 class="fw-bold mb-0">@Model.ProductCount</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center justify-content-center rounded-circle"
                         style="width:50px; height:50px; background: linear-gradient(135deg, #0891b2, #06b6d4);">
                        <i class="bi bi-grid-fill text-white fs-5"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Categories</p>
                        <h3 class="fw-bold mb-0">@Model.CategoryCount</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center justify-content-center rounded-circle"
                         style="width:50px; height:50px; background: linear-gradient(135deg, #065f46, #10b981);">
                        <i class="bi bi-people-fill text-white fs-5"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Total Users</p>
                        <h3 class="fw-bold mb-0">@Model.UserCount</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center justify-content-center rounded-circle"
                         style="width:50px; height:50px; background: linear-gradient(135deg, #dc2626, #ef4444);">
                        <i class="bi bi-shield-lock-fill text-white fs-5"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Admins</p>
                        <h3 class="fw-bold mb-0">@Model.AdminCount</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Links + Recent Products -->
    <div class="row g-3">
        <!-- Quick Links -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
                <div class="card-header bg-white border-0 pt-3 pb-0" style="border-radius: 1rem 1rem 0 0;">
                    <h6 class="fw-bold mb-0"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-light text-start d-flex align-items-center gap-2">
                            <i class="bi bi-book text-purple"></i> Manage Products
                        </a>
                        <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-light text-start d-flex align-items-center gap-2">
                            <i class="bi bi-grid text-info"></i> Manage Categories
                        </a>
                        <a asp-area="Admin" asp-controller="User" asp-action="Index" class="btn btn-light text-start d-flex align-items-center gap-2">
                            <i class="bi bi-people text-success"></i> Manage Users
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Products -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
                <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center" style="border-radius: 1rem 1rem 0 0;">
                    <h6 class="fw-bold mb-0"><i class="bi bi-clock-history text-primary me-2"></i>Recently Added Products</h6>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Product</th>
                                    <th>Category</th>
                                    <th>Author</th>
                                    <th class="text-end pe-3">Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in Model.RecentProducts)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <div class="d-flex align-items-center gap-2">
                                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                                {
                                                    <img src="@product.ImageUrl" alt="" style="width:36px; height:48px; object-fit:cover; border-radius:4px;" />
                                                }
                                                else
                                                {
                                                    <div class="d-flex align-items-center justify-content-center" style="width:36px; height:48px; background:#f3f4f6; border-radius:4px;">
                                                        <i class="bi bi-book text-muted"></i>
                                                    </div>
                                                }
                                                <span class="fw-medium">@product.Title</span>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-light text-dark">@product.Category?.Name</span></td>
                                        <td class="text-muted">@product.Author</td>
                                        <td class="text-end pe-3 fw-semibold">₺@product.Price.ToString("N2")</td>
                                    </tr>
                                }
                                @if (!Model.RecentProducts.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">No products yet</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
