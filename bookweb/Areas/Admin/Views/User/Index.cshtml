@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid px-4 py-4">
    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center" style="border-radius: 1rem 1rem 0 0;">
            <h5 class="fw-bold mb-0">
                <i class="bi bi-people-fill me-2" style="color: #065f46;"></i>User Management
            </h5>
        </div>
        <div class="card-body">
            <table id="tblData" class="table table-hover" style="width:100%">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Role</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/users.js"></script>
}
