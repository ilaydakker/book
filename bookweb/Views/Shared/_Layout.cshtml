<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - bookweb</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/bootswatchTheme.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/bookweb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.8/css/dataTables.dataTables.min.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100" style="background-color:#f5f5f5">
    <header class=" sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark" style="background-color:#191414">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="Customer" asp-controller="Home" asp-action="Index">
                    <div class="d-flex align-items-center justify-content-center rounded" style="width: 36px; height: 36px; background: rgba(255,255,255,0.2);">
                        <img src="/images/book.png" style="width: 24px; height: 24px;" />
                    </div>
                    <span class="fw-bold fs-5 d-none d-sm-inline">Book<span style="color: hotpink;">Web</span></span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                 aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse ">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link" asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.IsInRole(BookWeb.Utility.SD.Role_Admin))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Category" asp-action="Index">Category</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Product" asp-action="Index">Product</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="User" asp-action="Index">Users</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Customer" asp-controller="Home" asp-action="MyBooks">
                                    <i class="bi bi-book-half me-1"></i>My Books
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Customer" asp-controller="Home" asp-action="Shelves">
                                    <i class="bi bi-collection me-1"></i>My Shelves
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Customer" asp-controller="Cart" asp-action="Index">
                                    <i class="bi bi-cart3 me-1"></i>Cart
                                    <span class="badge rounded-pill bg-danger" id="cart-badge" style="font-size:0.6rem;display:none;"></span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Customer" asp-controller="Chat" asp-action="Index">
                                    <i class="bi bi-robot me-1"></i>Chat
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i>
                                    <span class="d-none d-md-inline">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
                                    <li>
                                        <a class="dropdown-item" asp-area="Customer" asp-controller="Home" asp-action="Profile">
                                            <i class="bi bi-person me-2"></i>My Profile
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm text-white ms-2 mt-1" asp-area="Identity" asp-page="/Account/Register"
                                   style="background: linear-gradient(135deg, #065f46, #10b981); border:none;">
                                    Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid p-0">
        <main role="main" class="pb-0">
            <partial name="_Notification" />
            @RenderBody()
        </main>
    </div>

    <footer class="mt-auto py-4" style="background: #0D0D0D;">
        <div class="container">
            <div class="row align-items-center gy-3">
                <div class="col-sm-4 d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px; background: hotpink;">
                        <i class="bi bi-book fs-5" style="color: #0D0D0D;"></i>
                    </div>
                    <div>
                        <p class="mb-0 fw-semibold text-white small">BookWeb</p>
                        <p class="mb-0 text-secondary" style="font-size: 0.75rem;">Your Gateway to Endless Stories</p>
                    </div>
                </div>
                <div class="col-sm-4 text-center">
                    <p class="mb-0 text-secondary small">&copy; @DateTime.Now.Year BookWeb. All rights reserved.</p>
                    <p class="mb-0 text-secondary" style="font-size: 0.75rem;">Made with <i class="bi bi-heart mx-1" style="color: hotpink;"></i> by IlaydaKoker</p>
                </div>
                <div class="col-sm-4 d-flex justify-content-sm-end justify-content-center gap-2">
                    <a href="#" class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background: rgba(255,255,255,0.1);">
                        <i class="bi bi-twitter-x text-secondary small"></i>
                    </a>
                    <a href="#" class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background: rgba(255,255,255,0.1);">
                        <i class="bi bi-facebook text-secondary small"></i>
                    </a>
                    <a href="#" class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background: rgba(255,255,255,0.1);">
                        <i class="bi bi-instagram text-secondary small"></i>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>"
    <script src="//cdn.datatables.net/2.3.8/js/dataTables.min.js" asp-append-version="true"></script>
    <script>
        $(function () {
            var badge = document.getElementById('cart-badge');
            if (badge) {
                $.get('/Customer/Cart/GetCartCount', function (data) {
                    if (data.count > 0) {
                        badge.textContent = data.count;
                        badge.style.display = 'inline';
                    }
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
